{
  "name": "ai-studio-angular-app",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "node dist/app/server/server.mjs",
    "dev": "cross-env ng serve --port=3000 --host=0.0.0.0 --allowed-hosts=true ${DISABLE_HMR:+--live-reload=false}",
    "build": "prisma generate && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "postinstall": "prisma generate",
    "serve:ssr:app": "node dist/app/server/server.mjs"
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "@google/genai": "^2.4.0",
    "@prisma/client": "^7.8.0",
    "@types/leaflet": "^1.9.21",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "leaflet": "^1.9.4",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.19",
    "@types/uuid": "^10.0.0",
    "angular-eslint": "21.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.0"
  }
}
