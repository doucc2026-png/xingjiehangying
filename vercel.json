{
  "version": 2,
  "builds": [
    {
      "src": "src/server.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/uploads/(.*)",
      "destination": "/uploads/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "src/server.ts"
    },
    {
      "source": "/(.*)",
      "destination": "src/server.ts"
    }
  ]
}
